# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Web Push VAPID (Sprint E)
# Generar con: npx web-push generate-vapid-keys
# La clave pública va aquí (expuesta al browser, es seguro)
# La clave privada va SOLO en Supabase → Settings → Edge Functions → Secrets
VITE_VAPID_PUBLIC_KEY=

# Supabase Edge Function secrets (NO poner aquí — van en Supabase Dashboard)
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:admin@tudominio.com
# SUPABASE_SERVICE_ROLE_KEY= (ya disponible automáticamente en Edge Functions)
